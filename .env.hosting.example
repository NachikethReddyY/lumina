# Hosting / production-style — copy to `.env.hosting` at the repo root.
# Activate with: `pnpm run dev:hosting` or `LUMINA_PROFILE=hosting`.
# Vite uses `--mode hosting` for dev and production build (see package.json).
# Leave NODE_ENV unset here; Vite sets production mode during `vite build`.
# On Vercel, you can rely on dashboard env vars instead of this file; use this for local runs against prod-like settings.

# Managed PostgreSQL connection (Supabase)
# URI format: postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB
DATABASE_SSL=true

PORT=5000
JWT_SECRET=use-a-long-random-secret
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=7d

# Your deployed site origin (used in email links)
FRONTEND_URL=https://your-app.vercel.app

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

GOOGLE_CLIENT_ID=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Supabase client ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# --- Frontend ---
# Leave unset so production uses same-origin `/api/v1` rewrites.
VITE_API_URL=
VITE_API_PREFIX=/api/v1
VITE_GOOGLE_CLIENT_ID=
