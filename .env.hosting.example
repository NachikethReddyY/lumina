# Hosting / production-style — copy to `.env.hosting` at the repo root.
# Activate with: `npm run dev:hosting` or `LUMINA_PROFILE=hosting`.
# Vite uses `--mode hosting` for dev and production build (see package.json).
# On Vercel, you can rely on dashboard env vars instead of this file; use this for local runs against prod-like settings.

NODE_ENV=production

# Managed PostgreSQL connection (Neon, Supabase, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB

PORT=5000
JWT_SECRET=use-a-long-random-secret
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=7d

# Your deployed site origin (used in email links)
FRONTEND_URL=https://your-app.vercel.app

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

GOOGLE_CLIENT_ID=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Frontend ---
# On Vercel with vercel.json rewrites, relative API is typical:
VITE_API_URL=/api/v1
VITE_API_PREFIX=/api/v1
VITE_GOOGLE_CLIENT_ID=
