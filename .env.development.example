# Local development — copy to `.env.development` at the repo root.
# Activate with: `npm run dev` (default) or `LUMINA_PROFILE=development`.
# Vite loads this file in `--mode development` (see package.json).

# --- Backend ---
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DB
PORT=5000
NODE_ENV=development

JWT_SECRET=change-me-dev-only
JWT_REFRESH_SECRET=optional-second-secret
JWT_ACCESS_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

GOOGLE_CLIENT_ID=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Frontend (VITE_* only) ---
VITE_API_URL=http://localhost:5000
VITE_API_PREFIX=/api/v1
VITE_GOOGLE_CLIENT_ID=
