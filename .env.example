# Database Connection
DATABASE_URL=postgresql://user:password@localhost:5432/lumina

# Server Configuration
PORT=5001
VITE_API_URL=http://localhost:5001
NODE_ENV=development

# JWT Secrets (for authentication)
JWT_SECRET=your-secret-key-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-here-min-32-chars
JWT_ACCESS_EXPIRES_IN=8h

FRONTEND_URL=http://localhost:5173,http://localhost:3000

# Gmail SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=your-email@gmail.com

# Lumina AI ticket routing provider configuration
# Set one of: opencode, groq, gemini, openrouter
LUMINA_PROVIDER=opencode
API_KEY=your-api-key-here
LUMINA_MODEL=deepseek-v4-flash-free

# Provider-specific model examples:
# OpenCode Zen free models:
#   deepseek-v4-flash-free, big-pickle, nemotron-3-super-free
# Groq: openai/gpt-oss-20b
# Gemini: gemini-2.0-flash
# OpenRouter: minimax/minimax-m2.5:free

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend (Vite reads repo-root .env — must match GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Idle session timeout — auto logout after inactivity. Units: s (seconds), m (minutes), h (hours).
# Examples: 300s, 5m, 30m, 1h, 2h. Bare numbers are treated as seconds (e.g. 300 = 5 minutes).
VITE_SESSION_TIMEOUT=1h
