# Copy to `.env` at the **repository root** (same folder as `backend/` and `react-user-dashboard/`).
# Backend always loads this path (never `backend/.env`). Vite uses `envDir: ..` so it reads the same file.
# Optional: `LUMINA_ENV_FILE=/other/path/.env` to load a different file (absolute or relative to shell cwd).
# Only variables prefixed with `VITE_` are exposed to the browser.

# --- Backend ---
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DB
PORT=5000
NODE_ENV=development

JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=optional-second-secret

# First origin is used in email links (activation, password reset). Include your Vite dev server.
FRONTEND_URL=http://localhost:5173

# Gmail SMTP (optional; if unset, signups skip email verification in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# --- Resend (optional; if set, takes priority over Mailgun/SMTP) ---
RESEND_API_KEY=
# Use an address on a verified domain, e.g. no-reply@yourdomain.com
RESEND_FROM_EMAIL=

GOOGLE_CLIENT_ID=

# Gemini routing (optional; if unset, ticket assignment falls back to rules-based routing)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Frontend (VITE_* only; must match GOOGLE_CLIENT_ID for Google Sign-In) ---
VITE_API_URL=http://localhost:5000
VITE_API_PREFIX=/api/v1
# Same OAuth Web Client ID as GOOGLE_CLIENT_ID above (required for @react-oauth/google).
VITE_GOOGLE_CLIENT_ID=
