{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/react-user-dashboard/$1"
    }
  ],
  "redirects": [
    {
      "source": "/react-user-dashboard",
      "destination": "/",
      "permanent": true
    }
  ],
  "functions": {
    "backend/server.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
